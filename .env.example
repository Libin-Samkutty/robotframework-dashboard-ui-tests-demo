# ============================================================================
# Environment Configuration for Dashboard UI Tests
# Copy this file to .env and fill in with your actual values
# ============================================================================

# === WEB DASHBOARD - CREDENTIALS ===
LOGIN_EMAIL=test.user@yourdomain.com
LOGIN_PASSWORD=your_secure_password_here

# === WEB DASHBOARD - URLS ===
BASE_URL_STAGING=https://staging.yourdomain.com/summary
BASE_URL_PROD=https://app.yourdomain.com/summary

# === CHATBOT - CONTACT DETAILS ===
AUTOMATION_USER_CONTACT=+1234567890
CHATBOT_STAGING_CONTACT=Demo App Staging
CHATBOT_PROD_CONTACT=Demo App Production

# === API - AUTHENTICATION ===
API_TOKEN=your_api_token_here
API_BASE_URL_STAGING=https://api-staging.yourdomain.com/v1
API_BASE_URL_PROD=https://api.yourdomain.com/v1

# === BROWSER SETTINGS ===
BROWSER=Chrome
# Options: Chrome, Firefox, Edge, Safari

# === ENVIRONMENT & LOCATION ===
ENV=STAGING
# Options: STAGING, PROD

COUNTRY=INDIA
# Options: INDIA, KENYA, NIGERIA

# === TIMEOUTS (in seconds) ===
DEFAULT_TIMEOUT=60
SHORT_TIMEOUT=3
VERY_SHORT_TIMEOUT=1

# === REPORT SETTINGS ===
REPORT_DIR=reports
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR

# === OPTIONAL: PROXY SETTINGS ===
# HTTP_PROXY=http://proxy.yourdomain.com:8080
# HTTPS_PROXY=https://proxy.yourdomain.com:8080
